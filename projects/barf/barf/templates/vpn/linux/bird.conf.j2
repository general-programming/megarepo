# /etc/bird/bird.conf - barf-managed bird2 base for {{ device.hostname }}.
# DO NOT HAND-EDIT: `barf config deploy {{ device.hostname }}` overwrites it.
#
# This file owns only the plumbing: logging, router id, and the
# device/kernel protocols. Routing policy and the BGP fabric live in
# drop-ins, included in GLOB (alphabetical) order:
#   /etc/bird/conf.d/00-local.conf -- this host's hand-written config,
#                                     tracked in network.yml (`bird:
#                                     local_conf`). Sorts first so its
#                                     definitions (e.g. the import
#                                     filter genprog references) parse
#                                     before genprog.conf.
#   /etc/bird/conf.d/genprog.conf  -- the barf-managed fabric.
#   /etc/bird/conf.d/<anything else> -- yours; barf never touches it.
log syslog all;
router id {{ router_id }};

protocol device {
	scan time 10;
}

protocol kernel {
{% if device.bird.get("merge_paths") %}
	merge paths on;
{% endif %}
	ipv4 {
		export filter {
			# Static routes are genprog_originate's announce anchors
			# (reject routes); installing them would blackhole the
			# very prefixes this host serves.
			if source = RTS_STATIC then reject;
{% if device.bird.get("krt_prefsrc") %}
			# Pin the source address of fabric-learned routes so
			# host-originated traffic uses our announced identity
			# (unnumbered links leave nothing else to pick from).
			krt_prefsrc = {{ device.bird["krt_prefsrc"] }};
{% endif %}
			accept;
		};
	};
}

protocol kernel {
	ipv6 {
		export where source != RTS_STATIC;
	};
}

include "/etc/bird/conf.d/*.conf";
