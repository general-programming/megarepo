# {{ device.hostname }} - generated by barf. RouterOS v7 CLI.
# Sections mirror the fabric contract the VyOS/linux hosts implement:
# WireGuard links, link addresses, eBGP to every spine, announced
# networks, and geographic path weighting (origin-site large
# communities in, local-pref out) when the host has a `site`.
{% for link in vpn_links %}
    {%- set interface_name = "wg" ~ link.link_id -%}
    {%- if link.side_a == device -%}
        {%- set our_side = link.side_a -%}
        {%- set other_peer = link.side_b -%}
    {%- else -%}
        {%- set our_side = link.side_b -%}
        {%- set other_peer = link.side_a -%}
    {%- endif %}
/interface/wireguard add name={{ interface_name }} listen-port={{ link.link_id }} mtu=1420 private-key="{{ link.wg_privkey(our_side) }}" comment="barf: {{ link.side_a.hostname }} -> {{ link.side_b.hostname }}"
/interface/wireguard/peers add interface={{ interface_name }} name={{ other_peer.hostname }} public-key="{{ link.wg_pubkey(other_peer) }}" allowed-address=0.0.0.0/0,::/0
{%- if other_peer.wg_endpoint %} endpoint-address={{ other_peer.wg_endpoint }} endpoint-port={{ link.link_id }} persistent-keepalive=10s{% endif %}

{% if link.unnumbered %}
{# Unnumbered (RFC 5549): the BGP session rides link-locals. ND must
   be enabled on the interface so we learn the peer's link-local from
   its RAs, and prefix=none lets this side answer RAs without any
   global address (live-verified on 7.22.3; ND multicast rides the
   tunnel because allowed-address covers ::/0). #}
{# /ipv6/nd entries silently discard comment= (accepted, never
   stored -- live-verified), so none is rendered: it would read as a
   forever-pending diff. #}
/ipv6/nd add interface={{ interface_name }} ra-interval=10s-15s
/ipv6/nd/prefix add prefix=none interface={{ interface_name }} comment="barf: {{ other_peer.hostname }} unnumbered BGP"
{% else %}
/ip/address add address={{ link.get_ip(our_side, with_netmask=True) }} interface={{ interface_name }} comment="barf: {{ other_peer.hostname }} link"
{% endif %}
{% endfor %}

{# LAN/L2 bridges modeled in network.yml (vendor-neutral interface
   type=bridge; the VyOS side renders the same model as `interfaces
   bridge`). barf owns the bridge by name, its L3 addresses, and its
   member ports (the /interface/bridge/port collection is owned for
   rendered bridges), so every member of an owned bridge must be
   modeled or it would be removed. #}
{% for iface in device.interfaces if iface.is_bridge %}
/interface/bridge add name={{ iface.name }}{% if iface.description %} comment="barf: {{ iface.description }}"{% endif %}

{% for member in iface.members %}
/interface/bridge/port add bridge={{ iface.name }} interface={{ member }}
{% endfor %}
{% for addr in iface.addresses %}
/ip/address add address={{ addr.with_prefixlen }} interface={{ iface.name }} comment="barf: {{ iface.name }} address"
{% endfor %}
{# LAN router-advertisement (host networking). Distinct from the fabric
   links' unnumbered RA: a real prefix RA for the attached hosts. #}
{% if iface.ra %}
/ipv6/nd add interface={{ iface.name }}{% if iface.ra.get('hop_limit') %} hop-limit={{ iface.ra.hop_limit }}{% endif %} advertise-dns={{ 'yes' if iface.ra.get('advertise_dns') else 'no' }}
{% endif %}
{% endfor %}

{# Static WireGuard tunnels (vendor-neutral `wireguard` block; the same
   model renders as `interfaces wireguard` on VyOS). External peerings,
   not the Vault-derived fabric mesh: the peer key/endpoint are static
   and our private key is captured into Vault off the device, so the
   interface adopts byte-identical without a rekey. Owned by rendered
   listen-port (ros_config._foreign_wg). #}
{% for iface in device.interfaces if iface.is_wireguard and iface.wireguard %}
    {%- set wg = iface.wireguard -%}
/interface/wireguard add name={{ iface.name }} listen-port={{ wg.port }} mtu={{ iface.mtu or 1420 }} private-key="{{ device.secret(wg.private_key_secret) }}" comment="barf: {{ iface.name }} tunnel"
{% for peer in wg.get('peers', []) %}
    {%- set endpoint = (" endpoint-address=" ~ peer.endpoint ~ " endpoint-port=" ~ peer.get('port', wg.port) ~ " persistent-keepalive=" ~ peer.get('keepalive', '10s')) if peer.get('endpoint') else "" -%}
/interface/wireguard/peers add interface={{ iface.name }} name={{ peer.name }} public-key="{{ peer.public_key }}" allowed-address={{ peer.get('allowed_ips', ['0.0.0.0/0', '::/0']) | join(',') }}{{ endpoint }}
{% endfor %}
{% for addr in iface.addresses %}
/ip/address add address={{ addr.with_prefixlen }} interface={{ iface.name }} comment="barf: {{ iface.name }} address"
{% endfor %}
{% endfor %}

{# Transit ASes are reflected into the fabric; their connected link
   nets are announced (and tagged) like our own networks so every
   fabric session, adopted or new, advertises identically. The far
   side of a transit link is not barf-managed: its wg interface and
   BGP session live outside barf's ownership scope, still filtered by
   the hand-written chain they reference. #}
{% set transit = device.bgp.get("transit", []) %}
{% set announced = device.networks + (transit | map(attribute="link_network") | list) %}
{% for network in announced %}
/ip/firewall/address-list add list=genprog-networks address={{ network }} comment="barf: announced to the fabric"
{% endfor %}

{% if origin_site %}
{# Tag our own originated prefixes with the origin-site large
   community (fabric-wide community_asn, RFC 8195 -- see
   barf/util/sites.py). With transit modeled the chain ends in an
   explicit reject -- this host does not re-export fabric routes
   between fabric peers (mirroring its hand-written `export` chain);
   without transit it stays accept-all like the rest of the fleet. #}
{% for network in announced %}
/routing/filter/rule add chain=genprog-out comment="barf: origin-site tag" rule="if (dst == {{ network }}) { set bgp-large-communities {{ community_asn }}:{{ SITE_ORIGIN_FUNC }}:{{ origin_site.id }}; accept }"
{% endfor %}
{% for t in transit %}
/routing/filter/rule add chain=genprog-out comment="barf: reflect {{ t.name }} (AS {{ t.remote_as }}) into the fabric" rule="if (dst-len != 0 && bgp-input-remote-as == {{ t.remote_as }}) { accept }"
{% endfor %}
{% if transit %}
/routing/filter/rule add chain=genprog-out comment="barf: no other re-export" rule="reject"
{% else %}
/routing/filter/rule add chain=genprog-out rule="accept"
{% endif %}
{% for site_name, rules in site_import_rules.items() %}
{% for rule in rules %}
/routing/filter/rule add chain=genprog-in-{{ site_name }} comment="barf: origin site {{ rule.site_id }}" rule="if (bgp-large-communities includes {{ community_asn }}:{{ SITE_ORIGIN_FUNC }}:{{ rule.site_id }}) { set bgp-local-pref {{ rule.local_pref }}; accept }"
{% endfor %}
/routing/filter/rule add chain=genprog-in-{{ site_name }} comment="barf: untagged fallthrough" rule="accept"
{% endfor %}
{% endif %}

/routing/bgp/template add name=genprog-fabric as={{ device.asn }} hold-time=30s keepalive-time=10s{% if announced %} output.network=genprog-networks{% endif %}

{# Unnumbered connections: local.address is the INTERFACE, no
   remote.address (the peer's link-local is discovered via ND), and
   afi=ip,ipv6 is mandatory -- the default afi=ip establishes but
   exchanges zero prefixes (live-learned). IPv4 NLRIs then ride IPv6
   next-hops via the extended-nexthop capability. #}
{% for link in vpn_links %}
    {%- set interface_name = "wg" ~ link.link_id -%}
    {%- set our_side = link.side_a if link.side_a == device else link.side_b -%}
    {%- set other_peer = link.side_b if link.side_a == device else link.side_a -%}
    {%- set weighted = site_import_rules.get(other_peer.site) -%}
    {%- set instance = " instance=" ~ device.bgp.instance if device.bgp.get("instance") else "" -%}
    {%- set policy = (" input.filter=genprog-in-" ~ other_peer.site if weighted else "")
                   ~ (" output.filter-chain=genprog-out" if origin_site else "") -%}
{% if link.unnumbered %}
/routing/bgp/connection add name={{ other_peer.hostname }} templates=genprog-fabric{{ instance }} local.address={{ interface_name }} local.role=ebgp remote.as={{ other_peer.asn }} afi=ip,ipv6{{ policy }} comment="barf: {{ other_peer.hostname }}"
{% else %}
/routing/bgp/connection add name={{ other_peer.hostname }} templates=genprog-fabric{{ instance }} remote.address={{ link.get_ip(other_peer) }} remote.as={{ other_peer.asn }} local.address={{ link.get_ip(our_side) }} local.role=ebgp{{ policy }} comment="barf: {{ other_peer.hostname }}"
{% endif %}
{% endfor %}

{# Transit BGP sessions barf now OWNS (was the hand `export` chain +
   `default` template). genprog-out-transit reproduces that chain's
   toward-transit rules verbatim from the model (the toward-fabric
   direction is already handled by genprog-out above); the session
   rides genprog-transit, a template shaped like the hand `default`
   (an AS, no output.network -- origination stays connected-matched).
   With the session pointed here, the hand `export` chain is no longer
   referenced and barf (owning all filter chains) deletes it.
   fabric_link_net is the fabric's numbered-link /31 pool. #}
{% set transit = device.bgp.get("transit", []) %}
{% if transit %}
{% set fabric_link_net = "172.31.255.0/24" %}
{% for t in transit %}
/routing/filter/rule add chain=genprog-out-transit comment="barf: export fabric routes to {{ t.name }} (AS {{ t.remote_as }})" rule="if (dst-len != 0 && bgp-output-remote-as == {{ t.remote_as }} && bgp-input-remote-as != {{ t.remote_as }}) {accept}"
/routing/filter/rule add chain=genprog-out-transit comment="barf: reflect {{ t.name }} routes to the fabric" rule="if (dst-len != 0 && bgp-output-remote-as != {{ t.remote_as }} && bgp-input-remote-as == {{ t.remote_as }}) {accept}"
/routing/filter/rule add chain=genprog-out-transit comment="barf: export {{ t.name }} link prefix to the fabric" rule="if (dst-len != 0 && protocol connected && dst in {{ t.export_supernet }} && bgp-output-remote-as != {{ t.remote_as }}) {accept}"
/routing/filter/rule add chain=genprog-out-transit comment="barf: export fabric link prefixes to {{ t.name }}" rule="if (dst-len != 0 && protocol connected && dst in {{ fabric_link_net }} && bgp-output-remote-as == {{ t.remote_as }}) {accept}"
{% endfor %}
/routing/filter/rule add chain=genprog-out-transit comment="barf: announce internal prefixes, drop other connected" rule="if (protocol connected && ({% for net in device.networks %}dst in {{ net }}{% if not loop.last %} or {% endif %}{% endfor %})) {accept} else {reject}"

/routing/bgp/template add name=genprog-transit as={{ device.asn }} routing-table=main
{% for t in transit %}
    {%- set instance = " instance=" ~ device.bgp.instance if device.bgp.get("instance") else "" -%}
/routing/bgp/connection add name={{ t.name }} templates=genprog-transit{{ instance }} remote.address={{ t.remote_address }} remote.as={{ t.remote_as }} local.role=ebgp output.filter-chain=genprog-out-transit comment="barf: {{ t.name }} transit"
{% endfor %}
{% endif %}

{% include 'common/all_suffix.j2' %}
