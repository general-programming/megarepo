#!/bin/sh
# Rendered by barf for {{ device.hostname }}.
#
# One quoted heredoc per barf-owned file. `barf config diff|deploy`
# parses these BARF_FILE blocks into a path -> content map and manages
# the files over SSH; running this script by hand writes the exact
# same contents (the delimiter is quoted, so nothing expands).
set -e
mkdir -p /etc/wireguard /etc/network/interfaces.d /etc/bird/conf.d

{% for link in vpn_links %}
cat << 'BARF_FILE' > /etc/wireguard/wg{{ link.link_id }}.conf
{% include "vpn/linux/wireguard.j2" %}
BARF_FILE
chmod 600 /etc/wireguard/wg{{ link.link_id }}.conf

cat << 'BARF_FILE' > /etc/network/interfaces.d/wg{{ link.link_id }}.conf
{% include "vpn/linux/ifupdown.j2" %}
BARF_FILE

{% endfor %}
{% for interface in device.interfaces if interface.name.startswith("dum") %}
cat << 'BARF_FILE' > /etc/network/interfaces.d/{{ interface.name }}.conf
{% include "vpn/linux/dummy.j2" %}
BARF_FILE

{% endfor %}
{% set router_id = device.bird.get("router_id") %}
{% if not router_id %}
{% set numbered = namespace(ip=None) %}
{% for link in vpn_links if not link.unnumbered %}
{% set our_side = link.side_a if link.side_a == device else link.side_b %}
{% if numbered.ip is none %}
{% set numbered.ip = link.get_ip(our_side) %}
{% endif %}
{% endfor %}
{% set router_id = numbered.ip or "192.0.2.1" %}
{% endif %}
cat << 'BARF_FILE' > /etc/bird/bird.conf
{% include "vpn/linux/bird.conf.j2" %}
BARF_FILE

{% if device.bird.get("local_conf") %}
{# Host-specific human bird config, tracked in network.yml
   (bird: local_conf). 00- so its definitions (e.g. the import
   filter genprog references) parse before genprog.conf. #}
cat << 'BARF_FILE' > /etc/bird/conf.d/00-local.conf
{{ device.bird["local_conf"].rstrip("\n") }}
BARF_FILE
{% endif %}

cat << 'BARF_FILE' > /etc/bird/conf.d/genprog.conf
{% include "vpn/linux/genprog.conf.j2" %}
BARF_FILE

birdc configure

{% include 'common/all_suffix.j2' %}
