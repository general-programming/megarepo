{% include 'common/vyos.j2' %}

set vpn ipsec esp-group ESP_DEFAULT lifetime '3600'
set vpn ipsec esp-group ESP_DEFAULT mode 'tunnel'
set vpn ipsec esp-group ESP_DEFAULT pfs enable
set vpn ipsec esp-group ESP_DEFAULT proposal 1 encryption 'aes256'
set vpn ipsec esp-group ESP_DEFAULT proposal 1 hash 'sha256'

set vpn ipsec ike-group IKEv2_DEFAULT key-exchange 'ikev2'
set vpn ipsec ike-group IKEv2_DEFAULT lifetime 28800
set vpn ipsec ike-group IKEv2_DEFAULT disable-mobike
set vpn ipsec ike-group IKEv2_DEFAULT proposal 1 dh-group 5
set vpn ipsec ike-group IKEv2_DEFAULT proposal 1 encryption aes256
set vpn ipsec ike-group IKEv2_DEFAULT proposal 1 hash sha256

set vpn ipsec interface eth0

{# Geographic BGP path weighting (large-community origin tagging +
   import local-pref); origin_site, community_asn, and the rules are
   prepared by barf/util/render.py -- see barf/util/sites.py for the
   distance math; route-maps below only render the already-computed
   integers. Tags carry the fabric-wide community_asn (RFC 8195 Global
   Administrator), never the per-host ASN, so importers (including
   bird peers, whose set grammar cannot wildcard the first field)
   match the exact triplet. #}
{% if origin_site %}
set policy route-map TAG-SITE-ORIGIN rule 10 action permit
set policy route-map TAG-SITE-ORIGIN rule 10 set large-community add '{{ community_asn }}:{{ SITE_ORIGIN_FUNC }}:{{ origin_site.id }}'
{% endif %}
{% if site_import_rules %}
{% for site in global_meta.get('sites', {}).values() | sort(attribute="id") %}
set policy large-community-list SITE-ORIGIN-{{ site.id }} rule 10 action permit
set policy large-community-list SITE-ORIGIN-{{ site.id }} rule 10 regex '^{{ community_asn }}:{{ SITE_ORIGIN_FUNC }}:{{ site.id }}$'
{% endfor %}
{% for site_name, rules in site_import_rules.items() %}
{% for rule in rules %}
set policy route-map IMPORT-{{ site_name | upper }} rule {{ loop.index * 10 }} action permit
set policy route-map IMPORT-{{ site_name | upper }} rule {{ loop.index * 10 }} match large-community large-community-list SITE-ORIGIN-{{ rule.site_id }}
set policy route-map IMPORT-{{ site_name | upper }} rule {{ loop.index * 10 }} set local-preference {{ rule.local_pref }}
{% endfor %}
set policy route-map IMPORT-{{ site_name | upper }} rule {{ (rules | length + 1) * 10 }} action permit
{% endfor %}
{% endif %}

{% for link in vpn_links %}
    {%- if link.side_a == device -%}
        {%- set our_side = link.side_a -%}
        {%- set other_peer = link.side_b -%}
    {%- else -%}
        {%- set our_side = link.side_b -%}
        {%- set other_peer = link.side_a -%}
    {%- endif -%}
    {# ipsec links#}
    {% if link.ipsec %}
        {%- set interface_name = "vti" ~ link.link_id -%}
        {%- set peer_name = "peer_" ~ other_peer.address.replace(".", "-") -%}
set interfaces vti {{ interface_name }} address '{{ link.get_ip(our_side) }}/31'

set vpn ipsec authentication psk {{ peer_name }} id '{{ our_side.address }}'
set vpn ipsec authentication psk {{ peer_name }} id '{{ other_peer.address }}'
set vpn ipsec authentication psk {{ peer_name }} id any
set vpn ipsec authentication psk {{ peer_name }} secret '{{ secrets[link.secret] }}'

set vpn ipsec site-to-site peer {{ peer_name }} description '{{ link.side_a.hostname }} -> {{ link.side_b.hostname }}'
set vpn ipsec site-to-site peer {{ peer_name }} authentication local-id '{{ our_side.address }}'
set vpn ipsec site-to-site peer {{ peer_name }} authentication mode 'pre-shared-secret'
set vpn ipsec site-to-site peer {{ peer_name }} authentication remote-id '{{ other_peer.address }}'
set vpn ipsec site-to-site peer {{ peer_name }} connection-type initiate
set vpn ipsec site-to-site peer {{ peer_name }} default-esp-group 'ESP_DEFAULT'
set vpn ipsec site-to-site peer {{ peer_name }} ike-group 'IKEv2_DEFAULT'
set vpn ipsec site-to-site peer {{ peer_name }} local-address any
set vpn ipsec site-to-site peer {{ peer_name }} remote-address '{{ other_peer.address }}'
set vpn ipsec site-to-site peer {{ peer_name }} vti bind '{{ interface_name }}'
set vpn ipsec site-to-site peer {{ peer_name }} vti esp-group 'ESP_DEFAULT'
    {% else %}
    {# wireguard links #}
        {%- set interface_name = "wg" ~ link.link_id -%}
        {%- set port = link.link_id -%}
set interfaces wireguard {{ interface_name }} description 'wg link ({{ link.side_a.hostname }} -> {{ link.side_b.hostname }})'
{% if not link.unnumbered %}
set interfaces wireguard {{ interface_name }} address {{ link.get_ip(our_side, with_netmask=True) }}
{% endif %}
set interfaces wireguard {{ interface_name }} private-key '{{ link.wg_privkey(our_side) }}'
set interfaces wireguard {{ interface_name }} port {{ port }}
set interfaces wireguard {{ interface_name }} peer {{ other_peer.hostname }} public-key '{{ link.wg_pubkey(other_peer) }}'
set interfaces wireguard {{ interface_name }} peer {{ other_peer.hostname }} allowed-ips 0.0.0.0/0
set interfaces wireguard {{ interface_name }} peer {{ other_peer.hostname }} allowed-ips ::/0
        {% if other_peer.wg_endpoint %}
set interfaces wireguard {{ interface_name }} peer {{ other_peer.hostname }} address {{ other_peer.wg_endpoint }}
set interfaces wireguard {{ interface_name }} peer {{ other_peer.hostname }} port {{ port }}
set interfaces wireguard {{ interface_name }} peer {{ other_peer.hostname }} persistent-keepalive 10
        {% endif %}
    {% endif %}

    {%- set bgp_neighbor = interface_name if link.unnumbered else link.get_ip(other_peer) -%}
{% if link.unnumbered %}
set protocols bgp neighbor {{ interface_name }} description '{{ other_peer.hostname }}'
set protocols bgp neighbor {{ interface_name }} update-source {{ device.management_address.ip }}
set protocols bgp neighbor {{ interface_name }} interface peer-group fabric
set protocols bgp neighbor {{ interface_name }} interface v6only peer-group fabric
set protocols bgp neighbor {{ interface_name }} interface v6only remote-as external
{% else %}
set protocols bgp neighbor {{ bgp_neighbor }} description '{{ other_peer.hostname }}'
set protocols bgp neighbor {{ bgp_neighbor }} remote-as external
set protocols bgp neighbor {{ bgp_neighbor }} update-source {{ device.management_address.ip }}
set protocols bgp neighbor {{ bgp_neighbor }} peer-group fabric
{% endif %}
    {% if other_peer.can_bfd %}
set protocols bgp neighbor {{ bgp_neighbor }} bfd
    {% endif %}
    {% if site_import_rules.get(other_peer.site) %}
set protocols bgp neighbor {{ bgp_neighbor }} address-family ipv4-unicast route-map import IMPORT-{{ other_peer.site | upper }}
set protocols bgp neighbor {{ bgp_neighbor }} address-family ipv6-unicast route-map import IMPORT-{{ other_peer.site | upper }}
    {% endif %}
{% endfor -%}

{# One line per network: the route-map suffix rides the same config
   node, so a separate bare `network X` line would read as a
   forever-pending diff against the device. #}
{% set tag_suffix = " route-map TAG-SITE-ORIGIN" if origin_site else "" %}
{% for network in device.networks %}
set protocols bgp address-family ipv4-unicast network {{ network }}{{ tag_suffix }}
{% endfor -%}
{% if ":" in device.management_address.with_prefixlen %}
set protocols bgp address-family ipv6-unicast network {{ device.management_address }}{{ tag_suffix }}
{% elif device.management_address %}
set protocols bgp address-family ipv4-unicast network {{ device.management_address }}{{ tag_suffix }}
{% endif %}

set protocols bgp system-as '{{ device.asn }}'
set protocols bgp peer-group fabric address-family ipv4-unicast
set protocols bgp peer-group fabric address-family ipv6-unicast
set protocols bgp peer-group fabric capability extended-nexthop
{# Numbered fabric peers (mikrotik) drop routes from the v6-only sea1
   spine without this: it lets FRR set a resolvable IPv4 next-hop
   instead of an unreachable one. Verified 2026-07-05 to fix
   sea420<->sea1 receiving 0 prefixes. #}
set protocols bgp peer-group fabric disable-connected-check
set protocols bgp timers keepalive 10
set protocols bgp timers holdtime 30

{% include 'common/all_suffix.j2' %}
