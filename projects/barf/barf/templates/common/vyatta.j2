set system host-name '{{ device.hostname }}'
set system domain-name '{{ global_meta.search_domain }}'
set system login user supertech authentication plaintext-password '{{ device.admin_password }}'
set service snmp community '{{ global_meta.snmp_public }}' authorization 'ro'
{% if device.snmp_location or global_meta.snmp_location %}
set service snmp location '{{ device.snmp_location or global_meta.snmp_location }}'
{% endif %}
set service snmp contact '{{ global_meta.snmp_contact }}'
{# set service ssh listen-address {{ device.management_ip }} #}
{% for dns_server in device.nameservers %}
set system name-server '{{ dns_server }}'
{% endfor %}

{# The factory-default empty loopback node; rendering it keeps the
   owned diff clean instead of fighting the default on every image. #}
set interfaces loopback lo

set system syslog local facility all level info
set system syslog local facility local7 level debug
set system console device ttyS0 speed 115200
set system config-management commit-revisions 100

{# Conntrack helpers: the vyatta-era defaults, set explicitly. #}
{% for module in ["ftp", "h323", "nfs", "pptp", "sip", "sqlnet", "tftp"] %}
set system conntrack modules {{ module }}
{% endfor %}
{# NTP lives in common/vyos.j2: the allow-client syntax is chrony-era
   VyOS, not shared vyatta lineage. #}
{% for interface in device.interfaces %}
    {# Dynamic addressing: each mechanism is an independent flag. #}
    {% if interface.dhcp %}
{{ device.interface_prefix(interface) }} address dhcp
    {% endif %}
    {% if interface.dhcpv6 %}
{{ device.interface_prefix(interface) }} address dhcpv6
    {% endif %}
    {% if interface.ipv6_autoconf %}
{{ device.interface_prefix(interface) }} ipv6 address autoconf
    {% endif %}
    {# Interface IPs, any mix of IPv4/IPv6. #}
    {% for addr in interface.addresses %}
{{ device.interface_prefix(interface) }} address {{ addr.with_prefixlen }}
    {% endfor %}
    {# Interface MTU. #}
    {% if interface.mtu %}
{{ device.interface_prefix(interface) }} mtu {{ interface.mtu }}
    {% endif %}
    {% if interface.description %}
{{ device.interface_prefix(interface) }} description '{{ interface.description }}'
    {% endif %}
    {# Bridge member ports (vendor-neutral `members` list). #}
    {% for member in interface.members %}
set interfaces bridge {{ interface.name }} member interface {{ member }}
    {% endfor %}
    {# Static WireGuard tunnel (vendor-neutral `wireguard` block); the
       fabric mesh links are rendered separately from vpn_links. #}
    {% if interface.is_wireguard and interface.wireguard %}
        {%- set wg = interface.wireguard -%}
{{ device.interface_prefix(interface) }} private-key '{{ device.secret(wg.private_key_secret) }}'
{{ device.interface_prefix(interface) }} port {{ wg.port }}
        {% for peer in wg.get('peers', []) %}
{{ device.interface_prefix(interface) }} peer {{ peer.name }} public-key '{{ peer.public_key }}'
            {% for ip in peer.get('allowed_ips', ['0.0.0.0/0', '::/0']) %}
{{ device.interface_prefix(interface) }} peer {{ peer.name }} allowed-ips '{{ ip }}'
            {% endfor %}
            {% if peer.get('endpoint') %}
{{ device.interface_prefix(interface) }} peer {{ peer.name }} address '{{ peer.endpoint }}'
{{ device.interface_prefix(interface) }} peer {{ peer.name }} port {{ peer.get('port', wg.port) }}
            {% endif %}
            {% if peer.get('keepalive') %}
{{ device.interface_prefix(interface) }} peer {{ peer.name }} persistent-keepalive {{ peer.keepalive | replace('s', '') }}
            {% endif %}
        {% endfor %}
    {% endif %}
{% endfor %}

set service ssh disable-password-authentication
{% for ssh_key in global_meta.ssh_keys %}
set system login user supertech authentication public-keys {{ ssh_key.split(" ")[2] }} key {{ ssh_key.split(" ")[1] }}
set system login user supertech authentication public-keys {{ ssh_key.split(" ")[2] }} type {{ ssh_key.split(" ")[0] }}
{% endfor %}

