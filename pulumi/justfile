# Pulumi state lives in the `pulumi-state` R2 bucket. Credentials are the
# static R2 access key/secret in Vault (secret/infra/cloudflare-r2), fetched
# by ../scripts/r2-creds.sh.
#
#   just login
#
# TODO once real stacks are added: `pulumi up`/`preview` also need
# AWS_ACCESS_KEY_ID/etc present at invocation time (same as tofu), and a
# secrets provider (e.g. PULUMI_CONFIG_PASSPHRASE) independent of this
# state-backend login — neither is wired up yet.

set shell := ["bash", "-euo", "pipefail", "-c"]

# Fetch R2 creds and log the local pulumi CLI into the R2 backend.
login:
    #!/usr/bin/env bash
    set -euo pipefail
    source <(../scripts/r2-creds.sh)
    pulumi login "s3://pulumi-state?endpoint=https://${CLOUDFLARE_ACCOUNT_ID}.r2.cloudflarestorage.com&region=auto&s3ForcePathStyle=true"
